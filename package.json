{
  "name": "fixthis",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "ci:local": "bash scripts/verify-ci-local.sh --full",
    "ci:local:prepush": "bash scripts/verify-ci-local.sh --prepush",
    "ci:local:fast": "bash scripts/verify-ci-local.sh --fast",
    "ci:local:changed": "bash scripts/verify-ci-local.sh --changed-only",
    "ci:local:test": "node --test scripts/verify-ci-local-test.mjs",
    "evidence": "node scripts/evidence-runner.mjs",
    "evidence:fast": "node scripts/evidence-runner.mjs --profile fast",
    "evidence:trust": "node scripts/evidence-runner.mjs --profile trust",
    "evidence:console": "node scripts/evidence-runner.mjs --profile console",
    "evidence:release": "node scripts/evidence-runner.mjs --profile release",
    "evidence:full": "node scripts/evidence-runner.mjs --profile full",
    "evidence:test": "node --test scripts/evidence-runner-test.mjs",
    "runtime-evidence:smoke": "node scripts/runtime-evidence-smoke.mjs",
    "runtime-evidence:smoke:test": "node --test scripts/runtime-evidence-smoke-test.mjs",
  "prepush": "./gradlew spotlessApply --no-daemon && FIXTHIS_BUNDLE_REPRODUCIBLE=1 node scripts/build-console-assets.mjs && npm run ci:local:prepush",
  "release:check": "npm run ci:local",
  "release:reality": "node scripts/release-reality-check.mjs",
  "release:gate": "node scripts/release-gate.mjs",
  "release:gate:test": "node --test scripts/release-gate-test.mjs scripts/console-reliability-report-test.mjs",
  "release:drift": "node scripts/release-drift-guard.mjs",
  "release:drift:test": "node --test scripts/release-drift-guard-test.mjs",
  "release:version:sync": "node scripts/sync-release-version.mjs",
  "release:version:check": "node scripts/sync-release-version.mjs --check && node --test scripts/release-version-contract-test.mjs",
  "release:homebrew:check": "node scripts/check-homebrew-formula-version.mjs",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "console:smoke": "node scripts/console-browser-smoke.mjs",
    "console:browser:reliability": "node scripts/console-browser-reliability.mjs",
    "first-run:smoke": "node scripts/first-run-smoke.mjs",
    "first-run:smoke:test": "node --test scripts/first-run-smoke-contract-test.mjs",
    "console:harness": "node scripts/console-harness.mjs",
    "console:responsive:stress": "node scripts/console-responsive-stress.mjs",
    "console:availability:test": "node scripts/run-console-tests.mjs availability",
    "console:pending:test": "node scripts/run-console-tests.mjs pending",
    "console:beforeunload:test": "node scripts/run-console-tests.mjs beforeunload",
    "console:undo:test": "node scripts/run-console-tests.mjs undo",
    "console:draft:test": "node scripts/run-console-tests.mjs draft",
    "console:activity:test": "node scripts/run-console-tests.mjs activity",
    "console:preview:test": "node scripts/run-console-tests.mjs preview",
    "console:session:test": "node scripts/run-console-tests.mjs session",
    "console:reliability:test": "node scripts/run-console-tests.mjs reliability",
    "console:harness:test": "node scripts/run-console-tests.mjs harness",
    "console:fsm:test": "node scripts/run-console-fsm-tests.mjs",
    "console:build:test": "node --test scripts/build-console-assets-test.mjs",
    "console:build:watch:test": "node --test scripts/build-console-assets-watch-test.mjs",
    "console:devReload:test": "node --test scripts/devReload-test.mjs",
    "console:serverBuildChip:test": "node --test scripts/serverBuildChip-test.mjs",
    "console:innerloop:test": "node scripts/run-console-tests.mjs innerloop",
    "console:test:fast": "node scripts/run-console-tests.mjs availability pending beforeunload undo activity preview innerloop",
    "console:test:all": "node scripts/run-console-tests.mjs availability canonical pending beforeunload undo activity preview draft session harness innerloop",
    "checks:observation": "node scripts/required-checks-observation.mjs",
    "checks:observation:test": "node --test scripts/required-checks-observation-test.mjs",
    "docs:agent-bootstrap:test": "node --test scripts/agent-bootstrap-contract-test.mjs",
    "detekt:baseline:check": "node scripts/check-detekt-baseline-budget.mjs",
    "perf:bench": "node scripts/perf/bench.mjs",
    "perf:compare": "node scripts/perf/compare-perf.mjs",
    "perf:test": "node --test scripts/perf/parse-gradle-profile-test.mjs scripts/perf/aggregate-test.mjs scripts/perf/compare-perf-test.mjs scripts/perf/perf-workflow-contract-test.mjs",
    "handoff:eval:test": "./gradlew :fixthis-mcp:test --tests \"*HandoffEvaluationCorpusTest\" --tests \"*EditSurfaceRoleClassifierTest\" --tests \"*EditSurfaceCandidateServiceTest\" --tests \"*CompactHandoffRendererTest.compactHandoffRendersEditSurfaceRoleWhenPresent\" --no-daemon",
    "source-matching:fixtures:prepare": "node scripts/source-matching-fixtures.mjs prepare",
    "source-matching:fixtures": "node scripts/source-matching-fixtures.mjs run",
    "source-matching:fixtures:runtime": "node scripts/source-matching-fixtures.mjs runtime",
  "source-matching:fixtures:report": "node scripts/source-matching-fixtures.mjs report",
  "source-matching:fixtures:test": "node --test scripts/source-matching-fixtures-test.mjs",
  "external-fixture:matrix": "node scripts/external-fixture-matrix.mjs",
  "external-fixture:matrix:test": "node --test scripts/external-fixture-matrix-test.mjs",
  "real-copy-prompt:smoke": "node scripts/real-copy-prompt-smoke.mjs",
  "real-copy-prompt:smoke:test": "node --test scripts/real-copy-prompt-smoke-test.mjs",
  "agent-loop:smoke": "node scripts/agent-loop-smoke.mjs",
  "agent-loop:smoke:test": "node --test scripts/agent-loop-smoke-test.mjs",
  "release:package:test": "node --test scripts/package-cli-release-test.mjs && node --test scripts/install-fixthis-test.mjs",
    "release:npm:test": "node --test scripts/npm-wrapper-test.mjs scripts/mcp-registry-metadata-test.mjs",
    "release:compat:test": "node --test scripts/android-compatibility-docs-test.mjs",
    "release:v06:claims:test": "node --test scripts/v06-release-claims-test.mjs",
    "release:v06:evidence:test": "node scripts/check-v06-release-evidence.mjs && npm run release:v06:claims:test && npm run release:compat:test && npm run release:version:check"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "github-slugger": "^2.0.0",
    "playwright": "^1.59.1"
  }
}

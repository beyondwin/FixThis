{
  "name": "fixthis",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "ci:local": "bash scripts/verify-ci-local.sh --full",
    "ci:local:fast": "bash scripts/verify-ci-local.sh --fast",
    "ci:local:changed": "bash scripts/verify-ci-local.sh --changed-only",
    "ci:local:test": "node --test scripts/verify-ci-local-test.mjs",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "console:smoke": "node scripts/console-browser-smoke.mjs",
    "first-run:smoke": "node scripts/first-run-smoke.mjs",
    "console:harness": "node scripts/console-harness.mjs",
    "console:responsive:stress": "node scripts/console-responsive-stress.mjs",
    "console:availability:test": "node scripts/run-console-tests.mjs availability",
    "console:pending:test": "node scripts/run-console-tests.mjs pending",
    "console:beforeunload:test": "node scripts/run-console-tests.mjs beforeunload",
    "console:undo:test": "node scripts/run-console-tests.mjs undo",
    "console:draft:test": "node scripts/run-console-tests.mjs draft",
    "console:activity:test": "node scripts/run-console-tests.mjs activity",
    "console:preview:test": "node scripts/run-console-tests.mjs preview",
    "console:session:test": "node scripts/run-console-tests.mjs session",
    "console:harness:test": "node scripts/run-console-tests.mjs harness",
    "console:fsm:test": "node scripts/run-console-fsm-tests.mjs",
    "console:build:test": "node --test scripts/build-console-assets-test.mjs",
    "console:test:fast": "node scripts/run-console-tests.mjs availability pending beforeunload undo activity preview",
    "console:test:all": "node scripts/run-console-tests.mjs availability canonical pending beforeunload undo activity preview draft session harness",
    "checks:observation": "node scripts/required-checks-observation.mjs",
    "detekt:baseline:check": "node scripts/check-detekt-baseline-budget.mjs",
    "perf:bench": "node scripts/perf/bench.mjs",
    "perf:compare": "node scripts/perf/compare-perf.mjs",
    "perf:test": "node --test scripts/perf/parse-gradle-profile-test.mjs scripts/perf/aggregate-test.mjs scripts/perf/compare-perf-test.mjs scripts/perf/perf-workflow-contract-test.mjs",
    "release:package:test": "node --test scripts/package-cli-release-test.mjs && node --test scripts/install-fixthis-test.mjs",
    "release:npm:test": "node --test scripts/npm-wrapper-test.mjs scripts/mcp-registry-metadata-test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "github-slugger": "^2.0.0",
    "playwright": "^1.59.1"
  }
}
